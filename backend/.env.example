# ============================================
# CephasGM GameZone - Environment Variables
# ============================================
# Copy this file to .env and update the values
# ============================================

# ============================================
# Application Settings
# ============================================

# Node environment: development, test, production
NODE_ENV=development

# Application port
PORT=3000

# Application URLs
APP_URL=http://localhost:3000
API_URL=http://localhost:3000

# CORS allowed origins (comma separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,https://gamezone.cephasgm.com

# ============================================
# Database - PostgreSQL
# ============================================

DB_HOST=localhost
DB_PORT=5432
DB_USER=cephasgm_user
DB_PASSWORD=secure_password_123
DB_NAME=cephasgm_gamezone

# ============================================
# Redis - Cache & Session
# ============================================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================
# JWT Authentication
# ============================================

# Generate with: openssl rand -base64 32
JWT_SECRET=change_me_to_a_secure_random_string
JWT_REFRESH_SECRET=change_me_to_a_secure_random_string

# Token expiration times
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
JWT_EMAIL_EXPIRY=24h
JWT_PASSWORD_RESET_EXPIRY=1h

# ============================================
# OAuth Providers
# ============================================

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=/api/v1/auth/oauth/google/callback

# Apple OAuth
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
APPLE_CALLBACK_URL=/api/v1/auth/oauth/apple/callback

# Facebook OAuth
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=/api/v1/auth/oauth/facebook/callback

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=/api/v1/auth/oauth/github/callback

# ============================================
# Payment Gateways
# ============================================

# ----- M-Pesa -----
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORT_CODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=/api/v1/payments/webhook/mpesa
MPESA_BASE_URL=https://api.safaricom.co.ke

# ----- Airtel Money -----
AIRTEL_API_KEY=
AIRTEL_API_SECRET=
AIRTEL_MERCHANT_ID=
AIRTEL_CALLBACK_URL=/api/v1/payments/webhook/airtel
AIRTEL_BASE_URL=https://api.airtel.africa

# ----- MixbyYas (Tanzania) -----
MIXBY_YAS_API_KEY=
MIXBY_YAS_API_SECRET=
MIXBY_YAS_MERCHANT_ID=
MIXBY_YAS_CALLBACK_URL=/api/v1/payments/webhook/mixbyyas
MIXBY_YAS_BASE_URL=https://api.mixbyyas.com/v1

# ----- Halopesa -----
HALOPESA_API_KEY=
HALOPESA_API_SECRET=
HALOPESA_MERCHANT_ID=
HALOPESA_CALLBACK_URL=/api/v1/payments/webhook/halopesa
HALOPESA_BASE_URL=https://api.halopesa.com/v1

# ----- PayPal -----
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_BASE_URL=https://api.paypal.com
PAYPAL_CALLBACK_URL=/api/v1/payments/webhook/paypal

# ----- Mobile Banking -----
MOBILE_BANKING_API_KEY=
MOBILE_BANKING_API_SECRET=
MOBILE_BANKING_BASE_URL=https://api.mobilebanking.com/v1
MOBILE_BANKING_CALLBACK_URL=/api/v1/payments/webhook/mobilebanking

# ----- Cryptocurrency -----
CRYPTO_PROVIDER=blockchain
CRYPTO_API_KEY=
CRYPTO_BASE_URL=https://api.blockchain.com/v3
CRYPTO_CALLBACK_URL=/api/v1/payments/webhook/crypto

# ============================================
# Email Service
# ============================================

# Provider: sendgrid, ses, nodemailer
EMAIL_PROVIDER=sendgrid

# SendGrid
SENDGRID_API_KEY=
FROM_EMAIL=noreply@cephasgm.com
FROM_NAME=CephasGM GameZone

# AWS SES
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# SMTP / Nodemailer
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# ============================================
# Push Notifications
# ============================================

# Provider: fcm, onesignal
PUSH_PROVIDER=fcm

# Firebase Cloud Messaging
FCM_SERVER_KEY=
FCM_PROJECT_ID=
FCM_SENDER_ID=

# OneSignal
ONESIGNAL_APP_ID=
ONESIGNAL_API_KEY=

# ============================================
# SMS Service
# ============================================

# Provider: twilio, africas_talking
SMS_PROVIDER=twilio

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Africa's Talking
AFRICAS_TALKING_API_KEY=
AFRICAS_TALKING_USERNAME=
AFRICAS_TALKING_FROM=CEPHASGM

# ============================================
# Odds Provider
# ============================================

ODDS_PROVIDER=mock
ODDS_API_KEY=
ODDS_BASE_URL=https://api.oddsprovider.com/v1
ODDS_REFRESH_INTERVAL=60000
ODDS_SPORT_IDS=football,basketball,tennis
ODDS_REGIONS=uk,us,eu
ODDS_MARKETS=h2h,spreads,totals
ODDS_WEBHOOK_SECRET=webhook_secret

# ============================================
# Security & Limits
# ============================================

# Rate Limiting
RATE_LIMIT_GLOBAL=100
RATE_LIMIT_AUTH_LOGIN=10
RATE_LIMIT_AUTH_REGISTER=5

# Session
SESSION_MAX_AGE=604800000
SESSION_IDLE_TIMEOUT=1800000
MAX_CONCURRENT_SESSIONS=5

# Password
PASSWORD_EXPIRY_DAYS=90

# Account Lockout
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=900

# Audit Log Retention (days)
AUDIT_LOG_RETENTION=365

# ============================================
# Logging
# ============================================

LOG_LEVEL=info
LOG_DIR=./logs

# ============================================
# File Uploads
# ============================================

MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,application/pdf

# ============================================
# Internal Services
# ============================================

INTERNAL_API_KEYS=

# ============================================
# Admin
# ============================================

ADMIN_EMAIL=admin@cephasgm.com
ADMIN_PASSWORD=Admin@123456

# ============================================
# SSL (Production)
# ============================================

# SSL_CERT_PATH=/etc/ssl/certs/cephasgm.crt
# SSL_KEY_PATH=/etc/ssl/private/cephasgm.key

# ============================================
# Docker (Override)
# ============================================

# For Docker Compose, these are set in docker-compose.yml
# DB_HOST=postgres
# REDIS_HOST=redis
